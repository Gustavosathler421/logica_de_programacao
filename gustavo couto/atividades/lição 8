# Projeto: Precisamos de um algoritmo para gerenciamento de cancelas para um shopping.
# Toda entrada e saída irá ser sinalizada
# Valores para entrada e permanência do veículo deverá ser pergutado 
# As entrada deverão ser registradas por placa.
# 
# Passo 1:  
# Perguntar informações sobre o veiculo ou forma acesso
# Pressionar o botao para emitir ticket
# Verificar se possui TAG para acesso liberado 
# Se possuir erros informar ao usuario

# Passo 2:
# Verificar tempo de permanencia
# Valor a ser cobrado

# Passo 3:
# Saida como sera?
# Calcular tempo de permanencia
# Se for tag gerar na fatura da tag
# Pagar ticket
# Devolver ticket na saida

# Passo 4:
# Gerar relatorio de entradas e saidas
# Tratamento de Erros
# Revisão do código

estacionamento = {
    "vagas_totais": 100,
    "vagas_ocupadas": 0,
    "veiculos": {} 
}
tags_cadastradas = ["TAG123", "TAG456", "ABC789"] 

def registrar_entrada():
    print("\n--- INICIANDO ENTRADA ---")
    placa = input("Digite a placa do veículo: ").upper()

    tem_tag = input("Possui TAG automática? (s/n): ").lower()
    
    if tem_tag == 's':
        tag_id = input("Aproxime a TAG (digite o código): ")
        if tag_id in tags_cadastradas:
            print(f"TAG {tag_id} reconhecida. Acesso livre para placa {placa}.")
            tipo = "TAG"
        else:
            print("Erro: TAG inválida ou não cadastrada. Solicitando ticket...")
            tipo = "Ticket"
    else:
        tipo = "Ticket"

    if tipo == "Ticket":
        print(f"Ticket emitido para placa {placa}. Hora: {datetime.datetime.now().strftime('%H:%M:%S')}")
    
    
    if estacionamento["vagas_ocupadas"] < estacionamento["vagas_totais"]:
        estacionamento["veiculos"][placa] = {
            "entrada": datetime.datetime.now(),
            "tipo": tipo
        }
        estacionamento["vagas_ocupadas"] += 1
        print("Cancela aberta. Veículo entrou.")
    else:
        print("Erro: Estacionamento lotado!")

def realizar_saida():
    print("\n--- INICIANDO SAÍDA ---")
    placa = input("Digite a placa para saída: ").upper()
    
    if placa not in estacionamento["veiculos"]:
        print("Erro: Veículo não encontrado no estacionamento.")
        return

    
    info = estacionamento["veiculos"][placa]
    tempo_entrada = info["entrada"]
    tempo_atual = datetime.datetime.now()
    duracao = tempo_atual - tempo_entrada
    
    print(f"Tempo de permanência: {duracao.total_seconds() / 60} minutos.")
    
    if info["tipo"] == "TAG":
        print("Pagamento automático realizado via TAG.")
    else:
    
        valor = 10.0 # Exemplo: R$10,00
        print(f"Valor a pagar: R${valor}")
        input("Pressione Enter para confirmar pagamento...")
    
    del estacionamento["veiculos"][placa]
    estacionamento["vagas_ocupadas"] -= 1
    print("Cancela de saída aberta. Obrigado.")

while True:
    opcao = input("\n1. Entrada\n2. Saída\n3. Sair\nEscolha: ")
    if opcao == '1':
        registrar_entrada()
    elif opcao == '2':
        realizar_saida()
    elif opcao == '3':
        break




    

 


